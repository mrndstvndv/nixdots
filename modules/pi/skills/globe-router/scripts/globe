#!/bin/bash

# Globe Router CLI - Interact with Globe At Home B9680 Router

set -u

ROUTER_IP_DEFAULT="192.168.254.254"
ROUTER_IP="${GLOBE_ROUTER_IP:-$ROUTER_IP_DEFAULT}"
COOKIE_FILE="/tmp/globe_router_cookies.txt"
BASE_URL=""
LOCAL_ENV_FILE="${GLOBE_ROUTER_ENV_FILE:-$HOME/.config/local/globe-router.env}"
KEYCHAIN_USER_SERVICE="globe-router-user"
KEYCHAIN_PASS_SERVICE="globe-router-pass"

CLI_ROUTER_USER=""
CLI_ROUTER_PASS=""
CLI_ROUTER_IP=""
RESOLVED_USER=""
RESOLVED_PASS=""

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

set_base_url() {
    BASE_URL="http://${ROUTER_IP}"
}

is_darwin() {
    [[ "$(uname -s)" == "Darwin" ]]
}

encode_b64() {
    echo -n "$1" | base64
}

strip_outer_quotes() {
    local value="$1"

    if [[ "$value" == \"*\" && "$value" == *\" ]]; then
        value="${value:1:${#value}-2}"
    elif [[ "$value" == \'*\' && "$value" == *\' ]]; then
        value="${value:1:${#value}-2}"
    fi

    printf '%s' "$value"
}

read_env_value() {
    local key="$1"
    local file="$2"
    local line
    local value

    [[ -f "$file" ]] || return 1

    line=$(grep -m1 "^${key}=" "$file" 2>/dev/null || true)
    [[ -n "$line" ]] || return 1

    value="${line#*=}"
    value="${value%$'\r'}"
    strip_outer_quotes "$value"
}

load_router_ip() {
    local env_file_ip

    if [[ -n "$CLI_ROUTER_IP" ]]; then
        ROUTER_IP="$CLI_ROUTER_IP"
        set_base_url
        return 0
    fi

    ROUTER_IP="${GLOBE_ROUTER_IP:-$ROUTER_IP_DEFAULT}"

    env_file_ip=$(read_env_value "GLOBE_ROUTER_IP" "$LOCAL_ENV_FILE" || true)
    if [[ -n "$env_file_ip" ]]; then
        ROUTER_IP="$env_file_ip"
    fi

    set_base_url
}

load_from_keychain() {
    local keychain_user
    local keychain_pass

    command -v security >/dev/null 2>&1 || return 1

    if [[ -z "$RESOLVED_USER" ]]; then
        keychain_user=$(security find-generic-password -s "$KEYCHAIN_USER_SERVICE" -a default -w 2>/dev/null || true)
        [[ -n "$keychain_user" ]] || return 1
        RESOLVED_USER="$keychain_user"
    fi

    if [[ -z "$RESOLVED_PASS" ]]; then
        keychain_pass=$(security find-generic-password -s "$KEYCHAIN_PASS_SERVICE" -a "$RESOLVED_USER" -w 2>/dev/null || true)
        [[ -n "$keychain_pass" ]] || return 1
        RESOLVED_PASS="$keychain_pass"
    fi

    return 0
}

load_from_env_file() {
    local env_user
    local env_pass

    [[ -f "$LOCAL_ENV_FILE" ]] || return 1

    env_user=$(read_env_value "GLOBE_ROUTER_USER" "$LOCAL_ENV_FILE" || true)
    env_pass=$(read_env_value "GLOBE_ROUTER_PASS" "$LOCAL_ENV_FILE" || true)

    [[ -z "$RESOLVED_USER" && -n "$env_user" ]] && RESOLVED_USER="$env_user"
    [[ -z "$RESOLVED_PASS" && -n "$env_pass" ]] && RESOLVED_PASS="$env_pass"

    [[ -n "$RESOLVED_USER" && -n "$RESOLVED_PASS" ]]
}

save_to_keychain() {
    local username="$1"
    local password="$2"

    command -v security >/dev/null 2>&1 || return 1

    security add-generic-password -U -s "$KEYCHAIN_USER_SERVICE" -a default -w "$username" >/dev/null
    security add-generic-password -U -s "$KEYCHAIN_PASS_SERVICE" -a "$username" -w "$password" >/dev/null
}

save_to_env_file() {
    local username="$1"
    local password="$2"

    mkdir -p "$(dirname "$LOCAL_ENV_FILE")"
    umask 077

    {
        printf 'GLOBE_ROUTER_USER=%s\n' "$username"
        printf 'GLOBE_ROUTER_PASS=%s\n' "$password"
        printf 'GLOBE_ROUTER_IP=%s\n' "$ROUTER_IP"
    } > "$LOCAL_ENV_FILE"

    chmod 600 "$LOCAL_ENV_FILE"
}

prompt_to_persist_credentials() {
    local choice
    local default_choice="n"

    if is_darwin && command -v security >/dev/null 2>&1; then
        default_choice="k"
    fi

    echo ""
    printf 'Save credentials? [k]eychain/[f]ile/[n]o (default: %s): ' "$default_choice"
    read -r choice
    choice="${choice:-$default_choice}"
    choice=$(printf '%s' "$choice" | tr '[:upper:]' '[:lower:]')

    case "$choice" in
        k|keychain)
            if save_to_keychain "$RESOLVED_USER" "$RESOLVED_PASS"; then
                echo "Saved to macOS Keychain."
                return 0
            fi
            echo -e "${RED}Failed to save to Keychain.${NC}"
            return 1
            ;;
        f|file)
            save_to_env_file "$RESOLVED_USER" "$RESOLVED_PASS"
            echo "Saved to $LOCAL_ENV_FILE"
            return 0
            ;;
        n|no)
            return 0
            ;;
        *)
            echo "Skipping save."
            return 0
            ;;
    esac
}

prompt_for_credentials() {
    local input_user
    local input_pass
    local default_user

    [[ -t 0 ]] || {
        echo "Credentials not found and no TTY available."
        echo "Use --user/--pass, environment variables, Keychain, or $LOCAL_ENV_FILE"
        return 1
    }

    default_user="${RESOLVED_USER:-admin}"

    printf 'Router username [%s]: ' "$default_user"
    read -r input_user
    RESOLVED_USER="${input_user:-$default_user}"

    printf 'Router password: '
    read -rs input_pass
    echo ""

    [[ -n "$input_pass" ]] || {
        echo "Password is required."
        return 1
    }

    RESOLVED_PASS="$input_pass"
    prompt_to_persist_credentials
}

resolve_credentials() {
    [[ -n "$RESOLVED_USER" && -n "$RESOLVED_PASS" ]] && return 0

    [[ -z "$RESOLVED_USER" && -n "$CLI_ROUTER_USER" ]] && RESOLVED_USER="$CLI_ROUTER_USER"
    [[ -z "$RESOLVED_PASS" && -n "$CLI_ROUTER_PASS" ]] && RESOLVED_PASS="$CLI_ROUTER_PASS"

    [[ -z "$RESOLVED_USER" && -n "${GLOBE_ROUTER_USER:-}" ]] && RESOLVED_USER="$GLOBE_ROUTER_USER"
    [[ -z "$RESOLVED_PASS" && -n "${GLOBE_ROUTER_PASS:-}" ]] && RESOLVED_PASS="$GLOBE_ROUTER_PASS"

    [[ -n "$RESOLVED_USER" && -n "$RESOLVED_PASS" ]] && return 0
    load_from_keychain && [[ -n "$RESOLVED_USER" && -n "$RESOLVED_PASS" ]] && return 0
    load_from_env_file && [[ -n "$RESOLVED_USER" && -n "$RESOLVED_PASS" ]] && return 0
    prompt_for_credentials
}

check_login() {
    local response

    response=$(curl -s -k -c "$COOKIE_FILE" -b "$COOKIE_FILE" \
        -X POST "${BASE_URL}/goform/goform_get_cmd_process" \
        -H "Content-Type: application/x-www-form-urlencoded" \
        -d "isTest=false&cmd=loginfo&multi_data=1")

    echo "$response" | grep -q '"loginfo":"ok"'
}

login() {
    local user_b64
    local pass_b64
    local response

    resolve_credentials || return 1

    user_b64=$(encode_b64 "$RESOLVED_USER")
    pass_b64=$(encode_b64 "$RESOLVED_PASS")

    echo -n "Logging in as $RESOLVED_USER... "

    response=$(curl -s -k -c "$COOKIE_FILE" -b "$COOKIE_FILE" \
        -X POST "${BASE_URL}/goform/goform_set_cmd_process" \
        -H "Content-Type: application/x-www-form-urlencoded" \
        -d "isTest=false&goformId=LOGIN&username=${user_b64}&password=${pass_b64}")

    if echo "$response" | grep -q '"result":"0"'; then
        echo -e "${GREEN}Success!${NC}"
        return 0
    fi

    echo -e "${RED}Failed!${NC}"
    echo "Response: $response"
    return 1
}

ensure_login() {
    if check_login; then
        return 0
    fi

    if ! login; then
        echo -e "${RED}Login failed.${NC}"
        exit 1
    fi
}

cmd_get() {
    local cmd="$1"
    local multi="${2:-1}"

    curl -s -k -c "$COOKIE_FILE" -b "$COOKIE_FILE" \
        -X POST "${BASE_URL}/goform/goform_get_cmd_process" \
        -H "Content-Type: application/x-www-form-urlencoded" \
        -d "isTest=false&cmd=${cmd}&multi_data=${multi}"
}

pretty_json() {
    jq . 2>/dev/null || python3 -m json.tool 2>/dev/null || cat
}

cmd_setup() {
    RESOLVED_USER=""
    RESOLVED_PASS=""
    prompt_for_credentials || return 1
    echo -e "${GREEN}Credentials ready.${NC}"
}

cmd_status() {
    ensure_login
    cmd_get "modem_main_state,network_type,sim_status,lte_plmn,lte_rsrq,lte_rssi1,lte_sinr,lte_pci,lte_enodebid,lte_cellid,wan_ipaddr,lan_ipaddr,ppp_status,rj45_state,sta_count,simcard_roam,SSID1,loginfo" | pretty_json
}

cmd_traffic() {
    ensure_login
    cmd_get "realtime_tx_thrpt,realtime_rx_thrpt,realtime_tx_bytes,realtime_rx_bytes,realtime_time,monthly_tx_bytes,monthly_rx_bytes,monthly_time" | pretty_json
}

cmd_device() {
    ensure_login
    cmd_get "wifi_coverage,m_ssid_enable,imei,cr_version,hardware_version,MAX_Access_num,SSID1,AuthMode,WPAPSK1_encode,m_SSID,m_AuthMode,m_WPAPSK1_encode,m_MAX_Access_num,lan_ipaddr,mac_address,msisdn,LocalDomain,wan_ipaddr,ipv6_wan_ipaddr,pdp_type,ppp_status,ethwan_mode" | pretty_json
}

cmd_wan() {
    ensure_login
    cmd_get "blc_wan_mode,blc_wan_auto_mode,dial_mode,ethwan_mode,default_wan_name,roam_setting_option,apn_name,apn_type,pdp_type,static_wan_ipaddr,static_wan_netmask,static_wan_gateway" | pretty_json
}

cmd_reboot() {
    local i

    ensure_login

    echo -e "${YELLOW}Rebooting router... This will take ~30 seconds${NC}"

    curl -s -k -c "$COOKIE_FILE" -b "$COOKIE_FILE" \
        -X POST "${BASE_URL}/goform/goform_set_cmd_process" \
        -H "Content-Type: application/x-www-form-urlencoded" \
        -d "isTest=false&goformId=REBOOT_DEVICE" >/dev/null 2>&1

    echo -n "Waiting for router to come back"
    for i in {1..30}; do
        sleep 1
        echo -n "."
        if curl -s -k -o /dev/null "${BASE_URL}/" 2>/dev/null; then
            echo -e " ${GREEN}Router is back!${NC}"
            sleep 2
            login >/dev/null 2>&1 || true
            echo -e "${GREEN}Reboot complete!${NC}"
            return 0
        fi
    done

    echo -e "\n${RED}Router did not respond. Check manually.${NC}"
    return 1
}

cmd_wan_connect() {
    local action="${1:-connect}"
    local goform_id="wan_connect"

    ensure_login

    if [[ "$action" != "connect" ]]; then
        goform_id="wan_disconnect"
    fi

    curl -s -k -c "$COOKIE_FILE" -b "$COOKIE_FILE" \
        -X POST "${BASE_URL}/goform/goform_set_cmd_process" \
        -H "Content-Type: application/x-www-form-urlencoded" \
        -d "isTest=false&goformId=${goform_id}" | pretty_json
}

cmd_wifi() {
    ensure_login
    cmd_get "SSID1,AuthMode,WPAPSK1_encode,m_SSID,m_AuthMode,m_WPAPSK1_encode,m_ssid_enable,sta_count,m_sta_count,wifi_cur_state,wifi_coverage" | pretty_json
}

cmd_sms() {
    ensure_login
    cmd_get "sms_received_flag,sts_received_flag,sms_unread_num" | pretty_json
}

cmd_signal() {
    ensure_login
    cmd_get "modem_main_state,network_type,lte_plmn,lte_rsrq,lte_rssi1,lte_sinr,lte_pci,lte_enodebid,lte_cellid,simcard_roam,web_signal" | pretty_json
}

cmd_raw() {
    local cmd="${1:-}"

    [[ -n "$cmd" ]] || {
        echo "raw requires a command string"
        exit 1
    }

    ensure_login
    cmd_get "$cmd" | pretty_json
}

cmd_help() {
    echo "Globe Router CLI - Commands:"
    echo ""
    echo "  setup       - Prompt for credentials and optionally save them"
    echo "  status      - Show basic status (network, IP, connection)"
    echo "  traffic     - Show traffic data (real-time & monthly)"
    echo "  device      - Show device information"
    echo "  wan         - Show WAN settings"
    echo "  wifi        - Show WiFi settings"
    echo "  signal      - Show signal information"
    echo "  sms         - Show SMS info"
    echo "  reboot      - Reboot the router"
    echo "  connect     - Connect WAN"
    echo "  disconnect  - Disconnect WAN"
    echo "  raw <cmd>   - Execute custom command"
    echo ""
    echo "Options:"
    echo "  --user <username>"
    echo "  --pass <password>"
    echo "  --ip <router_ip>"
    echo ""
    echo "Credential lookup order:"
    echo "  1. --user/--pass"
    echo "  2. GLOBE_ROUTER_USER / GLOBE_ROUTER_PASS"
    echo "  3. macOS Keychain"
    echo "  4. $LOCAL_ENV_FILE"
    echo "  5. Interactive prompt"
    echo ""
    echo "Usage: $0 [--user <username>] [--pass <password>] [--ip <router_ip>] <command>"
}

main() {
    local command

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --user)
                CLI_ROUTER_USER="${2:-}"
                shift 2
                ;;
            --pass)
                CLI_ROUTER_PASS="${2:-}"
                shift 2
                ;;
            --ip)
                CLI_ROUTER_IP="${2:-}"
                shift 2
                ;;
            help|--help|-h)
                cmd_help
                return 0
                ;;
            *)
                break
                ;;
        esac
    done

    load_router_ip

    command="${1:-help}"
    shift || true

    case "$command" in
        setup)       cmd_setup "$@" ;;
        status)      cmd_status "$@" ;;
        traffic)     cmd_traffic "$@" ;;
        device)      cmd_device "$@" ;;
        wan)         cmd_wan "$@" ;;
        wifi)        cmd_wifi "$@" ;;
        signal)      cmd_signal "$@" ;;
        sms)         cmd_sms "$@" ;;
        reboot)      cmd_reboot "$@" ;;
        connect)     cmd_wan_connect "connect" "$@" ;;
        disconnect)  cmd_wan_connect "disconnect" "$@" ;;
        raw)         cmd_raw "$@" ;;
        help|--help|-h) cmd_help ;;
        *)           echo "Unknown command: $command"; cmd_help; exit 1 ;;
    esac
}

main "$@"
