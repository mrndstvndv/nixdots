const HELP_TEXT = `mdview <path> [--host 0.0.0.0] [--port 3000]

Serve one Markdown file or a directory of Markdown files as mobile-friendly HTML, with server-side PDF export.

Flags:
  --host <host>   Bind host. Default: 0.0.0.0
  --port <port>   Bind port. Default: 3000
  --help          Show this help

PDF export:
  Append ?pdf=1 to a rendered Markdown page.
`;

main().catch(handleFatalError);

async function main() {
  const options = parseCliArgs(process.argv.slice(2));
  const appConfig = await resolveAppConfig(options.inputPath);
  const server = startServer(appConfig, options);

  printStartupInfo(appConfig, options);
  registerShutdown(server);
}

/**
 * @param {string[]} args
 * @returns {CliOptions}
 */
function parseCliArgs(args) {
  if (args.length === 0) fail("Missing path.\n\n" + HELP_TEXT);
  if (args.includes("--help") || args.includes("-h")) {
    console.log(HELP_TEXT);
    process.exit(0);
  }

  let inputPath = "";
  let host = DEFAULT_HOST;
  let port = DEFAULT_PORT;

  for (let index = 0; index < args.length; index += 1) {
    const arg = args[index];

    if (arg === "--host") {
      const value = args[index + 1];
      if (!value) fail("Missing value for --host");
      host = value;
      index += 1;
      continue;
    }

    if (arg.startsWith("--host=")) {
      host = arg.slice("--host=".length);
      continue;
    }

    if (arg === "--port") {
      const value = args[index + 1];
      if (!value) fail("Missing value for --port");
      port = parsePort(value);
      index += 1;
      continue;
    }

    if (arg.startsWith("--port=")) {
      port = parsePort(arg.slice("--port=".length));
      continue;
    }

    if (arg.startsWith("-")) fail(`Invalid flag: ${arg}`);
    if (inputPath) fail(`Unexpected extra argument: ${arg}`);

    inputPath = arg;
  }

  if (!inputPath) fail("Missing path.");
  if (!host.trim()) fail("Host must not be empty");

  return {
    inputPath,
    host,
    port,
  };
}

/**
 * @param {string} value
 * @returns {number}
 */
function parsePort(value) {
  if (!/^\d+$/.test(value)) fail(`Invalid port: ${value}`);

  const port = Number.parseInt(value, 10);
  if (port < 1 || port > 65535) fail(`Port out of range: ${value}`);

  return port;
}

/**
 * @param {string} inputPath
 * @returns {Promise<AppConfig>}
 */
async function resolveAppConfig(inputPath) {
  const absoluteInputPath = path.resolve(process.cwd(), inputPath);
  const inputStat = await getStat(absoluteInputPath);

  if (!inputStat) fail(`Path does not exist: ${absoluteInputPath}`);

  if (inputStat.isDirectory()) {
    const rootPath = await realpath(absoluteInputPath);
    return {
      mode: "directory",
      rootPath,
      servedPath: rootPath,
    };
  }

  if (!inputStat.isFile()) fail(`Unsupported path type: ${absoluteInputPath}`);
  if (!isMarkdownFile(absoluteInputPath)) fail(`Unsupported file type: ${absoluteInputPath}`);

  const filePath = await realpath(absoluteInputPath);
  return {
    mode: "file",
    rootPath: path.dirname(filePath),
    servedPath: filePath,
    filePath,
    relativePath: path.basename(filePath),
  };
}

/**
 * @param {AppConfig} appConfig
 * @param {CliOptions} options
 */
function startServer(appConfig, options) {
  try {
    return Bun.serve({
      hostname: options.host,
      port: options.port,
      fetch: (request) => handleRequest(request, appConfig),
      error: (error) => {
        console.error(error);
        return htmlResponse(renderErrorPage({
          title: "Internal render error",
          message: "mdview hit an unexpected server error.",
          status: 500,
          backHref: "/",
        }), 500, "GET");
      },
    });
  } catch (error) {
    if (isBusyPortError(error)) fail(`Port ${options.port} is already in use`);
    throw error;
  }
}

/**
 * @param {Request} request
 * @param {AppConfig} appConfig
 * @returns {Promise<Response>}
 */
async function handleRequest(request, appConfig) {
  const method = request.method.toUpperCase();
  if (method !== "GET" && method !== "HEAD") {
    return htmlResponse(renderErrorPage({
      title: "Method not allowed",
      message: "mdview only supports GET and HEAD requests.",
      status: 405,
      backHref: "/",
    }), 405, method);
  }

  try {
    if (appConfig.mode === "directory") {
      return await handleDirectoryRequest(request, appConfig);
    }

    return await handleFileRequest(request, appConfig);
  } catch (error) {
    console.error(error);
    return htmlResponse(renderErrorPage({
      title: "Internal render error",
      message: "mdview could not render that page.",
      status: 500,
      backHref: "/",
    }), 500, method);
  }
}

/**
 * @param {Request} request
 * @param {DirectoryConfig} appConfig
 * @returns {Promise<Response>}
 */
async function handleDirectoryRequest(request, appConfig) {
  const method = request.method.toUpperCase();
  const requestUrl = new URL(request.url);
  const pathname = requestUrl.pathname;
  const isPdf = isPdfExportRequested(requestUrl);

  if (pathname === "/") {
    const files = await listMarkdownFiles(appConfig.rootPath);
    return htmlResponse(renderIndexPage(appConfig.rootPath, files), 200, method);
  }

  if (pathname === "/view" || pathname === "/view/" || pathname === "/raw" || pathname === "/raw/") {
    return htmlResponse(renderErrorPage({
      title: "Invalid path",
      message: "That route needs a Markdown file path.",
      status: 400,
      backHref: "/",
    }), 400, method);
  }

  if (pathname.startsWith("/view/")) {
    return await renderDirectoryFileRoute({
      method,
      rootPath: appConfig.rootPath,
      routePath: pathname.slice("/view/".length),
      activeView: "rendered",
      isPdf,
    });
  }

  if (pathname.startsWith("/raw/")) {
    return await renderDirectoryFileRoute({
      method,
      rootPath: appConfig.rootPath,
      routePath: pathname.slice("/raw/".length),
      activeView: "raw",
      isPdf,
    });
  }

  // Serve static files (images, etc.) from the root directory
  if (!pathname.startsWith("/view/") && !pathname.startsWith("/raw/") && pathname !== "/") {
    const decodedPath = decodeRoutePath(pathname.slice(1)); // Remove leading /
    if (decodedPath) {
      const resolvedPath = path.resolve(appConfig.rootPath, decodedPath);
      if (isWithinPath(appConfig.rootPath, resolvedPath)) {
        const fileStat = await getStat(resolvedPath);
        if (fileStat && fileStat.isFile()) {
          const file = Bun.file(resolvedPath);
          return new Response(file, {
            headers: {
              "content-type": file.type || "application/octet-stream",
            },
          });
        }
      }
    }
  }

  return htmlResponse(renderErrorPage({
    title: "Not found",
    message: "That page does not exist under this mdview root.",
    status: 404,
    backHref: "/",
  }), 404, method);
}

/**
 * @param {Request} request
 * @param {FileConfig} appConfig
 * @returns {Promise<Response>}
 */
async function handleFileRequest(request, appConfig) {
  const method = request.method.toUpperCase();
  const requestUrl = new URL(request.url);
  const pathname = requestUrl.pathname;
  const isPdf = isPdfExportRequested(requestUrl);

  if (pathname === "/" || pathname === "") {
    return await renderFilePageResponse({
      method,
      filePath: appConfig.filePath,
      relativePath: appConfig.relativePath,
      rootPath: appConfig.rootPath,
      renderedHref: "/",
      rawHref: "/raw",
      backHref: "/",
      activeView: "rendered",
      isPdf,
    });
  }

  if (pathname === "/raw" || pathname === "/raw/") {
    return await renderFilePageResponse({
      method,
      filePath: appConfig.filePath,
      relativePath: appConfig.relativePath,
      rootPath: appConfig.rootPath,
      renderedHref: "/",
      rawHref: "/raw",
      backHref: "/",
      activeView: "raw",
      isPdf,
    });
  }

  return htmlResponse(renderErrorPage({
    title: "Not found",
    message: "File mode only serves / and /raw.",
    status: 404,
    backHref: "/",
  }), 404, method);
}

/**
 * @param {{ method: string; rootPath: string; routePath: string; activeView: "rendered" | "raw"; isPdf: boolean }} input
 * @returns {Promise<Response>}
 */
async function renderDirectoryFileRoute(input) {
  const decodedPath = decodeRoutePath(input.routePath);
  if (!decodedPath) {
    return htmlResponse(renderErrorPage({
      title: "Invalid path",
      message: "That Markdown path could not be decoded.",
      status: 400,
      backHref: "/",
    }), 400, input.method);
  }

  const resolved = await resolveDirectoryMarkdownPath(input.rootPath, decodedPath);
  if (resolved.kind === "invalid") {
    return htmlResponse(renderErrorPage({
      title: "Invalid path",
      message: "That request points outside the served root.",
      status: 400,
      backHref: "/",
    }), 400, input.method);
  }

  if (resolved.kind === "missing") {
    return htmlResponse(renderErrorPage({
      title: "Not found",
      message: "That Markdown file does not exist.",
      status: 404,
      backHref: "/",
    }), 404, input.method);
  }

  if (resolved.kind === "unsupported") {
    return htmlResponse(renderErrorPage({
      title: "Unsupported type",
      message: "mdview only serves .md and .markdown files.",
      status: 415,
      backHref: "/",
    }), 415, input.method);
  }

  return await renderFilePageResponse({
    method: input.method,
    filePath: resolved.filePath,
    relativePath: resolved.relativePath,
    rootPath: input.rootPath,
    renderedHref: `/view/${encodeRoutePath(resolved.relativePath)}`,
    rawHref: `/raw/${encodeRoutePath(resolved.relativePath)}`,
    backHref: "/",
    activeView: input.activeView,
    isPdf: input.isPdf,
  });
}

/**
 * @param {{ method: string; filePath: string; relativePath: string; rootPath: string; renderedHref: string; rawHref: string; backHref: string; activeView: "rendered" | "raw"; isPdf: boolean }} input
 * @returns {Promise<Response>}
 */
async function renderFilePageResponse(input) {
  const markdown = await Bun.file(input.filePath).text();
  const title = toFileTitle(input.relativePath);

  if (input.isPdf) {
    return await renderPdfResponse({
      method: input.method,
      markdown,
      title,
      relativePath: input.relativePath,
      rootPath: input.rootPath,
      sourcePath: input.filePath,
    });
  }

  if (input.activeView === "raw") {
    return htmlResponse(renderMarkdownPage({
      title,
      relativePath: input.relativePath,
      renderedHref: input.renderedHref,
      rawHref: input.rawHref,
      pdfHref: null,
      backHref: input.backHref,
      activeView: input.activeView,
      bodyHtml: `<section class="raw-body"><pre class="raw-block"><code>${escapeHtml(markdown)}</code></pre></section>`,
      hasMermaid: false,
    }), 200, input.method);
  }

  const rawHtml = Bun.markdown.html(markdown, MARKDOWN_OPTIONS);
  const renderedHtml = transformMermaidBlocks(rawHtml);
  return htmlResponse(renderMarkdownPage({
    title,
    relativePath: input.relativePath,
    renderedHref: input.renderedHref,
    rawHref: input.rawHref,
    pdfHref: appendQueryParam(input.renderedHref, "pdf", "1"),
    backHref: input.backHref,
    activeView: input.activeView,
    bodyHtml: `<article class="markdown-body">${renderedHtml}</article>`,
    hasMermaid: renderedHtml !== rawHtml,
  }), 200, input.method);
}

/**
 * @param {string} rootPath
 * @returns {Promise<MarkdownFile[]>}
 */
async function listMarkdownFiles(rootPath) {
  /** @type {MarkdownFile[]} */
  const files = [];
  await walkDirectory(rootPath, rootPath, files);
  files.sort((left, right) => left.relativePath.localeCompare(right.relativePath));
  return files;
}

/**
 * @param {string} rootPath
 * @param {string} directoryPath
 * @param {MarkdownFile[]} files
 * @returns {Promise<void>}
 */
async function walkDirectory(rootPath, directoryPath, files) {
  const entries = await readdir(directoryPath, { withFileTypes: true });
  entries.sort((left, right) => left.name.localeCompare(right.name));

  for (const entry of entries) {
    if (entry.isSymbolicLink()) continue;

    const entryPath = path.join(directoryPath, entry.name);

    if (entry.isDirectory()) {
      await walkDirectory(rootPath, entryPath, files);
      continue;
    }

    if (!entry.isFile()) continue;
    if (!isMarkdownFile(entryPath)) continue;

    const entryStat = await stat(entryPath);
    files.push({
      absolutePath: entryPath,
      relativePath: toRelativePath(rootPath, entryPath),
      modifiedAt: entryStat.mtime,
    });
  }
}

/**
 * @param {string} rootPath
 * @param {string} requestedPath
 * @returns {Promise<ResolveResult>}
 */
async function resolveDirectoryMarkdownPath(rootPath, requestedPath) {
  if (!requestedPath) return { kind: "invalid" };
  if (requestedPath.includes("\0") || requestedPath.includes("\\")) return { kind: "invalid" };

  const candidatePath = path.resolve(rootPath, requestedPath);
  if (!isWithinPath(rootPath, candidatePath)) return { kind: "invalid" };

  if (!isMarkdownFile(candidatePath)) return { kind: "unsupported" };

  const candidateStat = await getStat(candidatePath);
  if (!candidateStat || !candidateStat.isFile()) return { kind: "missing" };

  const realFilePath = await realpath(candidatePath);
  if (!isWithinPath(rootPath, realFilePath)) return { kind: "invalid" };

  return {
    kind: "ok",
    filePath: realFilePath,
    relativePath: toRelativePath(rootPath, realFilePath),
  };
}

/**
 * @param {string} html
 * @param {number} status
 * @param {string} method
 * @returns {Response}
 */
function htmlResponse(html, status, method) {
  return new Response(method === "HEAD" ? null : html, {
    status,
    headers: {
      "content-type": "text/html; charset=utf-8",
    },
  });
}

/**
 * @param {string} rootPath
 * @param {MarkdownFile[]} files
 * @returns {string}
 */
function renderIndexPage(rootPath, files) {
  const title = path.basename(rootPath) || rootPath;
  const nav = renderNav({
    backHref: "/",
    renderedHref: "/",
    rawHref: null,
    pdfHref: null,
    activeView: "index",
  });

  const bodyHtml = files.length === 0
    ? `<section class="surface empty-state"><p>No Markdown files found under this root.</p><p class="meta mono">${escapeHtml(rootPath)}</p></section>`
    : `<section class="surface surface-body"><ul class="file-list">${files.map(renderFileRow).join("")}</ul></section>`;

  return renderDocument({
    title: `${title} · mdview`,
    navHtml: nav,
    contentHtml: `
      <header class="page-header">
        <p class="eyebrow">Directory</p>
        <h1>${escapeHtml(title)}</h1>
        <p class="meta mono">${escapeHtml(rootPath)}</p>
        <p class="meta">${files.length} Markdown file${files.length === 1 ? "" : "s"}</p>
      </header>
      ${bodyHtml}
    `,
  });
}

/**
 * @param {MarkdownFile} file
 * @returns {string}
 */
function renderFileRow(file) {
  const renderedHref = `/view/${encodeRoutePath(file.relativePath)}`;
  const rawHref = `/raw/${encodeRoutePath(file.relativePath)}`;
  const title = toFileTitle(file.relativePath);

  return `
    <li class="file-row">
      <a class="file-card" href="${renderedHref}">
        <p class="file-title">${escapeHtml(title)}</p>
        <p class="file-path mono">${escapeHtml(file.relativePath)}</p>
        <p class="file-time">Updated ${escapeHtml(formatTimestamp(file.modifiedAt))}</p>
      </a>
      <div class="file-actions-row">
        <a class="file-action" href="${rawHref}">Raw</a>
      </div>
    </li>
  `;
}

/**
 * @param {{ title: string; relativePath: string; renderedHref: string; rawHref: string; pdfHref: string | null; backHref: string; activeView: "rendered" | "raw"; bodyHtml: string; hasMermaid?: boolean }} input
 * @returns {string}
 */
function renderMarkdownPage(input) {
  return renderDocument({
    title: `${input.title} · mdview`,
    navHtml: renderNav({
      backHref: input.backHref,
      renderedHref: input.renderedHref,
      rawHref: input.rawHref,
      pdfHref: input.pdfHref,
      activeView: input.activeView,
    }),
    contentHtml: `
      <header class="page-header">
        <p class="eyebrow">${input.activeView === "raw" ? "Raw" : "Rendered"}</p>
        <h1>${escapeHtml(input.title)}</h1>
        <p class="meta mono">${escapeHtml(input.relativePath)}</p>
      </header>
      ${input.bodyHtml}
    `,
    hasMermaid: input.hasMermaid,
  });
}

/**
 * @param {{ title: string; message: string; status: number; backHref: string | null }} input
 * @returns {string}
 */
function renderErrorPage(input) {
  return renderDocument({
    title: `${input.status} ${input.title} · mdview`,
    navHtml: renderNav({
      backHref: input.backHref,
      renderedHref: input.backHref ?? "/",
      rawHref: null,
      pdfHref: null,
      activeView: "error",
    }),
    contentHtml: `
      <header class="page-header">
        <p class="eyebrow">Error ${input.status}</p>
        <h1>${escapeHtml(input.title)}</h1>
        <p class="meta">${escapeHtml(input.message)}</p>
      </header>
      <section class="surface error-body">
        <p>${escapeHtml(input.message)}</p>
        ${input.backHref ? `<p><a href="${input.backHref}">Back to root</a></p>` : ""}
      </section>
    `,
  });
}

/**
 * @param {{ title: string; navHtml: string; contentHtml: string; hasMermaid?: boolean }} input
 * @returns {string}
 */
function renderDocument(input) {
  const mermaidScript = input.hasMermaid
    ? renderMermaidScript()
    : "";
  const langScripts = HIGHLIGHT_LANG_PACKS.map((url) => `<script src="${url}"></script>`).join("\n    ");

  return `<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
    <meta name="color-scheme" content="light dark">
    <title>${escapeHtml(input.title)}</title>
    <link rel="stylesheet" href="${HIGHLIGHT_CSS_URL}">
    <style>${STYLES}</style>
  </head>
  <body>
    <div class="page">
      <nav class="top-nav">${input.navHtml}</nav>
      <main class="shell">${input.contentHtml}</main>
    </div>
    <script src="${HIGHLIGHT_JS_URL}"></script>
    ${langScripts}
    <script>hljs.highlightAll();</script>
    ${mermaidScript}
  </body>
</html>`;
}

/**
 * @param {{ backHref: string | null; renderedHref: string; rawHref: string | null; pdfHref: string | null; activeView: "index" | "rendered" | "raw" | "error" }} input
 * @returns {string}
 */
function renderNav(input) {
  const actions = [];

  if (input.backHref) {
    actions.push(`<a class="pill" href="${input.backHref}">Back</a>`);
  }

  actions.push(`<a class="pill ${input.activeView === "rendered" || input.activeView === "index" ? "active" : ""}" href="${input.renderedHref}">${input.activeView === "index" ? "Index" : "Rendered"}</a>`);

  if (input.rawHref) {
    actions.push(`<a class="pill ${input.activeView === "raw" ? "active" : ""}" href="${input.rawHref}">Raw</a>`);
  }

  if (input.pdfHref) {
    actions.push(`<a class="pill" href="${input.pdfHref}" target="_blank" rel="noopener noreferrer">PDF</a>`);
  }

  return `
    <div class="nav-row">
      <a class="brand" href="/">mdview</a>
      <div class="nav-actions">${actions.join("")}</div>
    </div>
  `;
}

/**
 * @param {string} href
 * @param {string} name
 * @param {string} value
 * @returns {string}
 */
function appendQueryParam(href, name, value) {
  const url = new URL(href, "http://localhost");
  url.searchParams.set(name, value);
  return `${url.pathname}${url.search}${url.hash}`;
}

/**
 * @returns {string}
 */
function renderMermaidScript() {
  return `<script type="module">
  import mermaid from "https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs";
  const isDarkMode = window.matchMedia("(prefers-color-scheme: dark)").matches;
  mermaid.initialize({ startOnLoad: true, theme: isDarkMode ? "dark" : "default" });
</script>`;
}

/**
 * @param {URL} requestUrl
 * @returns {boolean}
 */
function isPdfExportRequested(requestUrl) {
  return requestUrl.searchParams.get("pdf") === "1" || requestUrl.searchParams.get("print") === "1";
}

/**
 * @param {{ method: string; markdown: string; title: string; relativePath: string; rootPath: string; sourcePath: string }} input
 * @returns {Promise<Response>}
 */
async function renderPdfResponse(input) {
  const pdfBuffer = await createPdfBuffer({
    markdown: input.markdown,
    title: input.title,
    rootPath: input.rootPath,
    sourcePath: input.sourcePath,
  });

  return new Response(input.method === "HEAD" ? null : pdfBuffer, {
    status: 200,
    headers: {
      "content-disposition": `inline; filename="${buildPdfFilename(input.relativePath)}"`,
      "content-type": "application/pdf",
    },
  });
}

/**
 * @param {{ markdown: string; title: string; rootPath: string; sourcePath: string }} input
 * @returns {Promise<Buffer>}
 */
async function createPdfBuffer(input) {
  const document = new PDFDocument({
    info: {
      Author: "mdview",
      Title: input.title,
    },
    margin: 54,
    size: "A4",
  });

  const bufferPromise = collectPdfBuffer(document);
  await renderMarkdownToPdf(document, input.markdown, {
    indent: 0,
    rootPath: input.rootPath,
    sourcePath: input.sourcePath,
  });
  document.end();
  return await bufferPromise;
}

/**
 * @param {InstanceType<typeof PDFDocument>} document
 * @returns {Promise<Buffer>}
 */
function collectPdfBuffer(document) {
  return new Promise((resolve, reject) => {
    const chunks = [];

    document.on("data", (chunk) => {
      chunks.push(Buffer.from(chunk));
    });

    document.on("end", () => {
      resolve(Buffer.concat(chunks));
    });

    document.on("error", reject);
  });
}

/**
 * @param {InstanceType<typeof PDFDocument>} document
 * @param {string} markdown
 * @param {PdfRenderContext} context
 * @returns {Promise<void>}
 */
async function renderMarkdownToPdf(document, markdown, context) {
  const tokens = /** @type {PdfToken[]} */ (marked.lexer(markdown, { gfm: true, breaks: false }));

  document.fillColor("#000000");
  document.font("Helvetica").fontSize(11.5);
  await renderPdfBlocks(document, tokens, context);
}

/**
 * @param {InstanceType<typeof PDFDocument>} document
 * @param {PdfToken[]} tokens
 * @param {PdfRenderContext} context
 * @returns {Promise<void>}
 */
async function renderPdfBlocks(document, tokens, context) {
  for (const token of stripSpaceTokens(tokens)) {
    await renderPdfBlock(document, token, context);
  }
}

/**
 * @param {InstanceType<typeof PDFDocument>} document
 * @param {PdfToken} token
 * @param {PdfRenderContext} context
 * @returns {Promise<void>}
 */
async function renderPdfBlock(document, token, context) {
  switch (token.type) {
    case "heading":
      await renderPdfHeading(document, token, context);
      return;
    case "paragraph":
      await renderPdfParagraph(document, token, context);
      return;
    case "list":
      await renderPdfList(document, token, context);
      return;
    case "blockquote":
      await renderPdfBlockquote(document, token, context);
      return;
    case "code":
      await renderPdfCode(document, token, context);
      return;
    case "table":
      await renderPdfTable(document, token, context);
      return;
    case "hr":
      renderPdfHr(document, context);
      return;
    case "html":
      await renderPdfHtml(document, token, context);
      return;
    default:
      return;
  }
}

/**
 * @param {InstanceType<typeof PDFDocument>} document
 * @param {PdfToken} token
 * @param {PdfRenderContext} context
 * @returns {Promise<void>}
 */
async function renderPdfHeading(document, token, context) {
  const headingTokens = token.tokens ?? [];
  const text = extractInlineText(headingTokens).trim() || (token.text ?? "").trim();
  if (!text) return;

  const depth = Math.min(Math.max(Number(token.depth ?? 1), 1), 6);
  const size = [20, 16, 14, 12.5, 11.5, 11.5][depth - 1];

  if (document.y > document.page.margins.top) {
    document.moveDown(depth === 1 ? 0.45 : 0.35);
  }

  // Headings are always bold
  const { x, width } = getPdfBlockBounds(document, context.indent);
  document.fillColor("#000000").font("Helvetica-Bold").fontSize(size);
  ensurePdfSpace(document, document.heightOfString(text, { width, lineGap: 2 }) + 8);
  document.text(text, x, document.y, { width, lineGap: 2 });
  document.moveDown(depth === 1 ? 0.35 : 0.25);
}

/**
 * @param {InstanceType<typeof PDFDocument>} document
 * @param {PdfToken} token
 * @param {PdfRenderContext} context
 * @returns {Promise<void>}
 */
async function renderPdfParagraph(document, token, context) {
  const paragraphTokens = stripSpaceTokens(token.tokens ?? []);
  if (paragraphTokens.length === 0) return;

  if (isStandaloneImageParagraph(paragraphTokens)) {
    await renderPdfImage(document, paragraphTokens[0], context);
    return;
  }

  const { x, width } = getPdfBlockBounds(document, context.indent);
  document.moveDown(0.25);
  renderPdfInlineTokens(document, paragraphTokens, x, width, context);
  document.moveDown(0.25);
}

/**
 * @param {InstanceType<typeof PDFDocument>} document
 * @param {PdfToken[]} tokens
 * @param {number} x
 * @param {number} width
 * @param {PdfRenderContext} context
 * @param {{ bold?: boolean; italic?: boolean }} [style]
 */
function renderPdfInlineTokens(document, tokens, x, width, context, style = {}) {
  const baseSize = 11.5;
  const lineGap = 2;

  for (const token of tokens) {
    renderPdfInlineToken(document, token, x, width, context, { ...style, size: baseSize, lineGap });
  }
}

/**
 * @param {InstanceType<typeof PDFDocument>} document
 * @param {PdfToken} token
 * @param {number} x
 * @param {number} width
 * @param {PdfRenderContext} context
 * @param {{ bold?: boolean; italic?: boolean; size?: number; lineGap?: number }} style
 */
function renderPdfInlineToken(document, token, x, width, context, style) {
  const size = style.size ?? 11.5;
  const lineGap = style.lineGap ?? 2;

  switch (token.type) {
    case "text":
    case "escape": {
      const text = token.text ?? token.raw ?? "";
      if (!text) return;
      const font = getPdfFont(style.bold, style.italic);
      document.fillColor("#000000").font(font).fontSize(size);
      ensurePdfSpace(document, document.heightOfString(text, { width, lineGap }) + 4);
      document.text(text, x, document.y, { width, lineGap, continued: false });
      return;
    }

    case "codespan": {
      const text = token.text ?? token.raw ?? "";
      if (!text) return;
      document.fillColor("#000000").font("Courier").fontSize(size * 0.92);
      ensurePdfSpace(document, document.heightOfString(text, { width, lineGap }) + 4);
      document.text(text, x, document.y, { width, lineGap, continued: false });
      return;
    }

    case "strong": {
      renderPdfInlineTokens(document, token.tokens ?? [], x, width, context, { ...style, bold: true });
      return;
    }

    case "em": {
      renderPdfInlineTokens(document, token.tokens ?? [], x, width, context, { ...style, italic: true });
      return;
    }

    case "del": {
      renderPdfInlineTokens(document, token.tokens ?? [], x, width, context, style);
      return;
    }

    case "link": {
      const linkTokens = token.tokens ?? [];
      if (linkTokens.length > 0) {
        renderPdfInlineTokens(document, linkTokens, x, width, context, { ...style, italic: true });
      } else {
        const text = token.text ?? "";
        if (text) {
          document.fillColor("#000000").font("Helvetica-Oblique").fontSize(size);
          ensurePdfSpace(document, document.heightOfString(text, { width, lineGap }) + 4);
          document.text(text, x, document.y, { width, lineGap, continued: false });
        }
      }
      return;
    }

    case "br": {
      document.moveDown(0.5);
      return;
    }

    case "image": {
      // Inline images in paragraphs - just show alt text
      const altText = token.text ?? "";
      if (altText) {
        document.fillColor("#000000").font("Helvetica-Oblique").fontSize(size);
        ensurePdfSpace(document, document.heightOfString(altText, { width, lineGap }) + 4);
        document.text(altText, x, document.y, { width, lineGap, continued: false });
      }
      return;
    }

    case "html": {
      const text = stripHtml(token.raw ?? token.text ?? "");
      if (!text.trim()) return;
      const font = getPdfFont(style.bold, style.italic);
      document.fillColor("#000000").font(font).fontSize(size);
      ensurePdfSpace(document, document.heightOfString(text, { width, lineGap }) + 4);
      document.text(text, x, document.y, { width, lineGap, continued: false });
      return;
    }

    default: {
      // Fallback for any other token types
      if (token.tokens && token.tokens.length > 0) {
        renderPdfInlineTokens(document, token.tokens, x, width, context, style);
      } else {
        const text = token.text ?? token.raw ?? "";
        if (text) {
          const font = getPdfFont(style.bold, style.italic);
          document.fillColor("#000000").font(font).fontSize(size);
          ensurePdfSpace(document, document.heightOfString(text, { width, lineGap }) + 4);
          document.text(text, x, document.y, { width, lineGap, continued: false });
        }
      }
      return;
    }
  }
}

/**
 * @param {boolean} [bold]
 * @param {boolean} [italic]
 * @returns {string}
 */
function getPdfFont(bold, italic) {
  if (bold && italic) return "Helvetica-BoldOblique";
  if (bold) return "Helvetica-Bold";
  if (italic) return "Helvetica-Oblique";
  return "Helvetica";
}

/**
 * @param {InstanceType<typeof PDFDocument>} document
 * @param {PdfToken} token
 * @param {PdfRenderContext} context
 * @returns {Promise<void>}
 */
async function renderPdfList(document, token, context) {
  const items = token.items ?? [];
  if (items.length === 0) return;

  let counter = Number.parseInt(String(token.start ?? 1), 10);
  if (Number.isNaN(counter) || counter < 1) {
    counter = 1;
  }

  for (const item of items) {
    const itemTokens = stripSpaceTokens(item.tokens ?? []);
    if (itemTokens.length === 0) {
      if (token.ordered) counter += 1;
      continue;
    }

    const bullet = token.ordered
      ? `${counter}.`
      : item.task
        ? item.checked
          ? "[x]"
          : "[ ]"
        : "•";

    const { inlineTokens, blockTokens } = splitInlineAndBlockTokens(itemTokens);
    const { x, width } = getPdfBlockBounds(document, context.indent);
    const bulletText = `${bullet} `;
    
    // Render bullet
    document.fillColor("#000000").font("Helvetica").fontSize(11.5);
    ensurePdfSpace(document, 20);
    document.text(bulletText, x, document.y, { width, continued: true, lineGap: 2 });
    
    // Render inline content with formatting
    const afterBulletX = x + document.widthOfString(bulletText);
    const afterBulletWidth = Math.max(72, width - document.widthOfString(bulletText));
    renderPdfInlineTokens(document, inlineTokens, afterBulletX, afterBulletWidth, context);
    
    if (blockTokens.length > 0) {
      await renderPdfBlocks(document, blockTokens, { indent: context.indent + 18 });
    }

    document.moveDown(0.15);
    if (token.ordered) counter += 1;
  }
}

/**
 * @param {InstanceType<typeof PDFDocument>} document
 * @param {PdfToken} token
 * @param {PdfRenderContext} context
 * @returns {Promise<void>}
 */
async function renderPdfBlockquote(document, token, context) {
  const quoteTokens = stripSpaceTokens(token.tokens ?? []);
  if (quoteTokens.length === 0) return;

  document.moveDown(0.1);
  await renderPdfBlocks(document, quoteTokens, { indent: context.indent + 18 });
  document.moveDown(0.1);
}

/**
 * @param {InstanceType<typeof PDFDocument>} document
 * @param {PdfToken} token
 * @param {PdfRenderContext} context
 * @returns {Promise<void>}
 */
async function renderPdfCode(document, token, context) {
  const code = (token.text ?? token.raw ?? "").replace(/\n+$/, "");
  if (!code.trim()) return;

  renderPdfTextBlock(document, code, context, {
    font: "Courier",
    size: 10,
    lineGap: 2,
    moveDown: 0.3,
  });
}

/**
 * @param {InstanceType<typeof PDFDocument>} document
 * @param {PdfToken} token
 * @param {PdfRenderContext} context
 * @returns {Promise<void>}
 */
async function renderPdfTable(document, token, context) {
  const rows = [];
  if (token.header) rows.push(token.header);
  if (token.rows) rows.push(...token.rows);

  const lines = rows
    .map((row) => row.map((cell) => extractInlineText(cell.tokens ?? []).trim()).join(" | "))
    .filter((line) => line.trim());

  if (lines.length === 0) return;

  renderPdfTextBlock(document, lines.join("\n"), context, {
    font: "Courier",
    size: 10,
    lineGap: 2,
    moveDown: 0.2,
  });
}

/**
 * @param {InstanceType<typeof PDFDocument>} document
 * @param {PdfRenderContext} context
 */
function renderPdfHr(document, context) {
  const { x, width } = getPdfBlockBounds(document, context.indent);

  ensurePdfSpace(document, 12);
  const lineY = document.y + 5;

  document.save();
  document.strokeColor("#c7c7c7").lineWidth(0.75);
  document.moveTo(x, lineY).lineTo(x + width, lineY).stroke();
  document.restore();
  document.y = lineY + 7;
}

/**
 * @param {InstanceType<typeof PDFDocument>} document
 * @param {PdfToken} token
 * @param {PdfRenderContext} context
 * @returns {Promise<void>}
 */
async function renderPdfHtml(document, token, context) {
  const text = stripHtml(token.raw ?? token.text ?? "");
  if (!text.trim()) return;

  renderPdfTextBlock(document, text, context, {
    font: "Helvetica",
    size: 11.5,
    lineGap: 2,
    moveDown: 0.2,
  });
}

/**
 * @param {InstanceType<typeof PDFDocument>} document
 * @param {PdfToken} token
 * @param {PdfRenderContext} context
 * @returns {Promise<void>}
 */
async function renderPdfImage(document, token, context) {
  const imageSource = await resolvePdfImageSource(context.rootPath, context.sourcePath, token.href ?? "");
  if (!imageSource) {
    const fallbackText = (token.text ?? token.href ?? "").trim();
    if (fallbackText) {
      renderPdfTextBlock(document, `[image: ${fallbackText}]`, context, {
        font: "Helvetica-Oblique",
        size: 10.5,
        lineGap: 2,
        moveDown: 0.25,
      });
    }
    return;
  }

  let image;
  try {
    image = document.openImage(imageSource);
  } catch {
    const fallbackText = (token.text ?? token.href ?? "").trim();
    if (fallbackText) {
      renderPdfTextBlock(document, `[image: ${fallbackText}]`, context, {
        font: "Helvetica-Oblique",
        size: 10.5,
        lineGap: 2,
        moveDown: 0.25,
      });
    }
    return;
  }

  const bounds = getPdfBlockBounds(document, context.indent);
  const maxHeight = document.page.height - document.page.margins.top - document.page.margins.bottom;
  const scale = Math.min(bounds.width / image.width, maxHeight / image.height, 1);
  const imageWidth = image.width * scale;
  const imageHeight = image.height * scale;

  ensurePdfSpace(document, imageHeight + 12);

  const x = bounds.x + Math.max(0, (bounds.width - imageWidth) / 2);
  const y = document.y;
  document.image(imageSource, x, y, { width: imageWidth });
  document.y = y + imageHeight + 8;
}

/**
 * @param {string} rootPath
 * @param {string} sourcePath
 * @param {string} href
 * @returns {Promise<string | null>}
 */
async function resolvePdfImageSource(rootPath, sourcePath, href) {
  const cleanedHref = stripImageHref(href);
  if (!cleanedHref) return null;
  if (cleanedHref.startsWith("//")) return null;
  if (/^[a-zA-Z][a-zA-Z\d+\-.]*:/.test(cleanedHref)) return null;

  const decodedHref = decodeRoutePath(cleanedHref) ?? cleanedHref;
  const resolvedPath = decodedHref.startsWith("/")
    ? path.join(rootPath, decodedHref)
    : path.resolve(path.dirname(sourcePath), decodedHref);

  if (!isWithinPath(rootPath, resolvedPath)) return null;

  const fileStat = await getStat(resolvedPath);
  if (!fileStat || !fileStat.isFile()) return null;

  return resolvedPath;
}

/**
 * @param {string} href
 * @returns {string}
 */
function stripImageHref(href) {
  return href.trim().split("#")[0].split("?")[0].trim();
}

/**
 * @param {PdfToken[]} tokens
 * @returns {boolean}
 */
function isStandaloneImageParagraph(tokens) {
  return tokens.length === 1 && tokens[0].type === "image";
}

/**
 * @param {InstanceType<typeof PDFDocument>} document
 * @param {string} text
 * @param {PdfRenderContext} context
 * @param {{ font?: string; size?: number; lineGap?: number; moveDown?: number }} [options]
 */
function renderPdfTextBlock(document, text, context, options = {}) {
  const { x, width } = getPdfBlockBounds(document, context.indent);
  const font = options.font ?? "Helvetica";
  const size = options.size ?? 11.5;
  const lineGap = options.lineGap ?? 2;
  const moveDown = options.moveDown ?? 0.25;

  document.fillColor("#000000");
  document.font(font).fontSize(size);
  ensurePdfSpace(document, document.heightOfString(text, { width, lineGap }) + 8);
  document.text(text, x, document.y, { width, lineGap });

  if (moveDown > 0) {
    document.moveDown(moveDown);
  }
}

/**
 * @param {InstanceType<typeof PDFDocument>} document
 * @param {number} requiredHeight
 */
function ensurePdfSpace(document, requiredHeight) {
  const remainingHeight = document.page.height - document.page.margins.bottom - document.y;
  if (remainingHeight >= requiredHeight) return;

  document.addPage();
}

/**
 * @param {InstanceType<typeof PDFDocument>} document
 * @param {number} indent
 * @returns {{ x: number; width: number }}
 */
function getPdfBlockBounds(document, indent) {
  const contentWidth = document.page.width - document.page.margins.left - document.page.margins.right;
  const effectiveIndent = Math.min(Math.max(indent, 0), Math.max(0, contentWidth - 72));
  const x = document.page.margins.left + effectiveIndent;
  const width = Math.max(72, contentWidth - effectiveIndent);

  return {
    x,
    width,
  };
}

/**
 * @param {PdfToken[]} tokens
 * @returns {string}
 */
function extractInlineText(tokens) {
  return tokens.map((token) => extractTokenText(token)).join("");
}

/**
 * @param {PdfToken} token
 * @returns {string}
 */
function extractTokenText(token) {
  if (token.type === "text" || token.type === "escape" || token.type === "codespan") {
    return token.text ?? token.raw ?? "";
  }

  if (token.type === "br") {
    return "\n";
  }

  if (token.type === "image") {
    return token.text ?? "";
  }

  if (token.type === "link") {
    const linkText = extractInlineText(token.tokens ?? []).trim() || (token.text ?? "");
    return token.href ? `${linkText} (${token.href})` : linkText;
  }

  if (token.type === "html") {
    return stripHtml(token.raw ?? token.text ?? "");
  }

  if (token.tokens) {
    return extractInlineText(token.tokens);
  }

  return token.text ?? token.raw ?? "";
}

/**
 * @param {PdfToken[]} tokens
 * @returns {PdfToken[]}
 */
function stripSpaceTokens(tokens) {
  return tokens.filter((token) => token.type !== "space");
}

/**
 * @param {PdfToken[]} tokens
 * @returns {{ inlineTokens: PdfToken[]; blockTokens: PdfToken[] }}
 */
function splitInlineAndBlockTokens(tokens) {
  const inlineTokens = [];
  const blockTokens = [];
  let blockStarted = false;

  for (const token of tokens) {
    if (!blockStarted && isInlinePdfToken(token)) {
      inlineTokens.push(token);
      continue;
    }

    blockStarted = true;
    blockTokens.push(token);
  }

  return {
    inlineTokens,
    blockTokens,
  };
}

/**
 * @param {PdfToken} token
 * @returns {boolean}
 */
function isInlinePdfToken(token) {
  return token.type === "text"
    || token.type === "escape"
    || token.type === "codespan"
    || token.type === "strong"
    || token.type === "em"
    || token.type === "link"
    || token.type === "image"
    || token.type === "br"
    || token.type === "del"
    || token.type === "html";
}

/**
 * @param {string} value
 * @returns {string}
 */
function stripHtml(value) {
  return value.replace(/<[^>]*>/g, "");
}

/**
 * @param {string} relativePath
 * @returns {string}
 */
function buildPdfFilename(relativePath) {
  const title = toFileTitle(relativePath)
    .normalize("NFKD")
    .replace(/[^\w.-]+/g, "-")
    .replace(/-+/g, "-")
    .replace(/^-+|-+$/g, "");

  return `${title || "document"}.pdf`;
}

/**
 * @param {string} value
 * @returns {string | null}
 */
function decodeRoutePath(value) {
  try {
    return decodeURIComponent(value);
  } catch {
    return null;
  }
}

/**
 * @param {string} value
 * @returns {string}
 */
function encodeRoutePath(value) {
  return value
    .split("/")
    .map((segment) => encodeURIComponent(segment))
    .join("/");
}

/**
 * @param {string} filePath
 * @returns {boolean}
 */
function isMarkdownFile(filePath) {
  return ALLOWED_EXTENSIONS.has(path.extname(filePath).toLowerCase());
}

/**
 * @param {string} rootPath
 * @param {string} targetPath
 * @returns {boolean}
 */
function isWithinPath(rootPath, targetPath) {
  const root = path.resolve(rootPath);
  const target = path.resolve(targetPath);
  const fileSystemRoot = path.parse(root).root;

  if (root === fileSystemRoot) return target.startsWith(root);
  if (target === root) return true;

  return target.startsWith(`${root}${path.sep}`);
}

/**
 * @param {string} rootPath
 * @param {string} filePath
 * @returns {string}
 */
function toRelativePath(rootPath, filePath) {
  return path.relative(rootPath, filePath).split(path.sep).join("/");
}

/**
 * @param {string} relativePath
 * @returns {string}
 */
function toFileTitle(relativePath) {
  const basename = path.basename(relativePath);
  return basename.replace(/\.(md|markdown)$/i, "") || basename;
}

/**
 * @param {Date} date
 * @returns {string}
 */
function formatTimestamp(date) {
  return date.toLocaleString(undefined, {
    dateStyle: "medium",
    timeStyle: "short",
  });
}

/**
 * Convert <pre><code class="language-mermaid">...</code></pre> blocks into
 * <div class="mermaid">...</div> so Mermaid.js can render them client-side.
 * @param {string} html
 * @returns {string}
 */
function transformMermaidBlocks(html) {
  return html.replace(
    /<pre><code class="language-mermaid">([\s\S]*?)<\/code><\/pre>/g,
    (_match, content) => `<div class="mermaid">${unescapeMinimalHtmlEntities(content)}</div>`,
  );
}

/**
 * Decode the minimal set of HTML entities that Bun.markdown.html() emits.
 * @param {string} value
 * @returns {string}
 */
function unescapeMinimalHtmlEntities(value) {
  return value
    .replaceAll("&amp;", "&")
    .replaceAll("&lt;", "<")
    .replaceAll("&gt;", ">")
    .replaceAll("&quot;", '"')
    .replaceAll("&#39;", "'");
}

/**
 * @param {string} value
 * @returns {string}
 */
function escapeHtml(value) {
  return value
    .replaceAll("&", "&amp;")
    .replaceAll("<", "&lt;")
    .replaceAll(">", "&gt;")
    .replaceAll('"', "&quot;")
    .replaceAll("'", "&#39;");
}

/**
 * @param {AppConfig} appConfig
 * @param {CliOptions} options
 */
function printStartupInfo(appConfig, options) {
  const localHost = isExposedHost(options.host) ? "127.0.0.1" : options.host;
  const lanHost = detectLanHost();

  console.log(`mdview serving: ${appConfig.servedPath}`);
  console.log(`mode: ${appConfig.mode}`);
  console.log(`local url: ${buildUrl(localHost, options.port)}`);

  if (isExposedHost(options.host) && lanHost) {
    console.log(`lan url: ${buildUrl(lanHost, options.port)}`);
  }

  if (options.host === DEFAULT_HOST) {
    console.log("warning: server is exposed on all interfaces");
  }
}

/**
 * @returns {string | null}
 */
function detectLanHost() {
  const interfaces = os.networkInterfaces();

  for (const addresses of Object.values(interfaces)) {
    if (!addresses) continue;

    for (const address of addresses) {
      if (address.family !== "IPv4") continue;
      if (address.internal) continue;
      return address.address;
    }
  }

  return null;
}

/**
 * @param {string} host
 * @param {number} port
 * @returns {string}
 */
function buildUrl(host, port) {
  const formattedHost = host.includes(":") && !host.startsWith("[") ? `[${host}]` : host;
  return `http://${formattedHost}:${port}`;
}

/**
 * @param {string} host
 * @returns {boolean}
 */
function isExposedHost(host) {
  return host === "0.0.0.0" || host === "::";
}

/**
 * @param {ReturnType<typeof Bun.serve>} server
 */
function registerShutdown(server) {
  const stop = () => {
    server.stop(true);
    process.exit(0);
  };

  process.on("SIGINT", stop);
  process.on("SIGTERM", stop);
}

/**
 * @param {string} filePath
 * @returns {Promise<import("node:fs").Stats | null>}
 */
async function getStat(filePath) {
  try {
    return await stat(filePath);
  } catch {
    return null;
  }
}

/**
 * @param {unknown} error
 * @returns {boolean}
 */
function isBusyPortError(error) {
  if (!(error instanceof Error)) return false;

  return error.message.includes("EADDRINUSE") || error.message.toLowerCase().includes("address already in use");
}

/**
 * @param {unknown} error
 */
function handleFatalError(error) {
  if (error instanceof Error) fail(error.message);
  fail(String(error));
}

/**
 * @param {string} message
 * @returns {never}
 */
function fail(message) {
  console.error(`error: ${message}`);
  process.exit(1);
}
