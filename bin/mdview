const HELP_TEXT = `mdview <path> [--host 0.0.0.0] [--port 3000]

Serve one Markdown file or a directory of Markdown files as mobile-friendly HTML.

Flags:
  --host <host>   Bind host. Default: 0.0.0.0
  --port <port>   Bind port. Default: 3000
  --help          Show this help
`;

main().catch(handleFatalError);

async function main() {
  const options = parseCliArgs(process.argv.slice(2));
  const appConfig = await resolveAppConfig(options.inputPath);
  const server = startServer(appConfig, options);

  printStartupInfo(appConfig, options);
  registerShutdown(server);
}

/**
 * @param {string[]} args
 * @returns {CliOptions}
 */
function parseCliArgs(args) {
  if (args.length === 0) fail("Missing path.\n\n" + HELP_TEXT);
  if (args.includes("--help") || args.includes("-h")) {
    console.log(HELP_TEXT);
    process.exit(0);
  }

  let inputPath = "";
  let host = DEFAULT_HOST;
  let port = DEFAULT_PORT;

  for (let index = 0; index < args.length; index += 1) {
    const arg = args[index];

    if (arg === "--host") {
      const value = args[index + 1];
      if (!value) fail("Missing value for --host");
      host = value;
      index += 1;
      continue;
    }

    if (arg.startsWith("--host=")) {
      host = arg.slice("--host=".length);
      continue;
    }

    if (arg === "--port") {
      const value = args[index + 1];
      if (!value) fail("Missing value for --port");
      port = parsePort(value);
      index += 1;
      continue;
    }

    if (arg.startsWith("--port=")) {
      port = parsePort(arg.slice("--port=".length));
      continue;
    }

    if (arg.startsWith("-")) fail(`Invalid flag: ${arg}`);
    if (inputPath) fail(`Unexpected extra argument: ${arg}`);

    inputPath = arg;
  }

  if (!inputPath) fail("Missing path.");
  if (!host.trim()) fail("Host must not be empty");

  return {
    inputPath,
    host,
    port,
  };
}

/**
 * @param {string} value
 * @returns {number}
 */
function parsePort(value) {
  if (!/^\d+$/.test(value)) fail(`Invalid port: ${value}`);

  const port = Number.parseInt(value, 10);
  if (port < 1 || port > 65535) fail(`Port out of range: ${value}`);

  return port;
}

/**
 * @param {string} inputPath
 * @returns {Promise<AppConfig>}
 */
async function resolveAppConfig(inputPath) {
  const absoluteInputPath = path.resolve(process.cwd(), inputPath);
  const inputStat = await getStat(absoluteInputPath);

  if (!inputStat) fail(`Path does not exist: ${absoluteInputPath}`);

  if (inputStat.isDirectory()) {
    const rootPath = await realpath(absoluteInputPath);
    return {
      mode: "directory",
      rootPath,
      servedPath: rootPath,
    };
  }

  if (!inputStat.isFile()) fail(`Unsupported path type: ${absoluteInputPath}`);
  if (!isMarkdownFile(absoluteInputPath)) fail(`Unsupported file type: ${absoluteInputPath}`);

  const filePath = await realpath(absoluteInputPath);
  return {
    mode: "file",
    rootPath: path.dirname(filePath),
    servedPath: filePath,
    filePath,
    relativePath: path.basename(filePath),
  };
}

/**
 * @param {AppConfig} appConfig
 * @param {CliOptions} options
 */
function startServer(appConfig, options) {
  try {
    return Bun.serve({
      hostname: options.host,
      port: options.port,
      fetch: (request) => handleRequest(request, appConfig),
      error: (error) => {
        console.error(error);
        return htmlResponse(renderErrorPage({
          title: "Internal render error",
          message: "mdview hit an unexpected server error.",
          status: 500,
          backHref: "/",
        }), 500, "GET");
      },
    });
  } catch (error) {
    if (isBusyPortError(error)) fail(`Port ${options.port} is already in use`);
    throw error;
  }
}

/**
 * @param {Request} request
 * @param {AppConfig} appConfig
 * @returns {Promise<Response>}
 */
async function handleRequest(request, appConfig) {
  const method = request.method.toUpperCase();
  if (method !== "GET" && method !== "HEAD") {
    return htmlResponse(renderErrorPage({
      title: "Method not allowed",
      message: "mdview only supports GET and HEAD requests.",
      status: 405,
      backHref: "/",
    }), 405, method);
  }

  try {
    if (appConfig.mode === "directory") {
      return await handleDirectoryRequest(request, appConfig);
    }

    return await handleFileRequest(request, appConfig);
  } catch (error) {
    console.error(error);
    return htmlResponse(renderErrorPage({
      title: "Internal render error",
      message: "mdview could not render that page.",
      status: 500,
      backHref: "/",
    }), 500, method);
  }
}

/**
 * @param {Request} request
 * @param {DirectoryConfig} appConfig
 * @returns {Promise<Response>}
 */
async function handleDirectoryRequest(request, appConfig) {
  const method = request.method.toUpperCase();
  const pathname = new URL(request.url).pathname;

  if (pathname === "/") {
    const files = await listMarkdownFiles(appConfig.rootPath);
    return htmlResponse(renderIndexPage(appConfig.rootPath, files), 200, method);
  }

  if (pathname === "/view" || pathname === "/view/" || pathname === "/raw" || pathname === "/raw/") {
    return htmlResponse(renderErrorPage({
      title: "Invalid path",
      message: "That route needs a Markdown file path.",
      status: 400,
      backHref: "/",
    }), 400, method);
  }

  if (pathname.startsWith("/view/")) {
    return await renderDirectoryFileRoute({
      method,
      rootPath: appConfig.rootPath,
      routePath: pathname.slice("/view/".length),
      activeView: "rendered",
    });
  }

  if (pathname.startsWith("/raw/")) {
    return await renderDirectoryFileRoute({
      method,
      rootPath: appConfig.rootPath,
      routePath: pathname.slice("/raw/".length),
      activeView: "raw",
    });
  }

  return htmlResponse(renderErrorPage({
    title: "Not found",
    message: "That page does not exist under this mdview root.",
    status: 404,
    backHref: "/",
  }), 404, method);
}

/**
 * @param {Request} request
 * @param {FileConfig} appConfig
 * @returns {Promise<Response>}
 */
async function handleFileRequest(request, appConfig) {
  const method = request.method.toUpperCase();
  const pathname = new URL(request.url).pathname;

  if (pathname === "/" || pathname === "") {
    return await renderFilePageResponse({
      method,
      filePath: appConfig.filePath,
      relativePath: appConfig.relativePath,
      renderedHref: "/",
      rawHref: "/raw",
      backHref: "/",
      activeView: "rendered",
    });
  }

  if (pathname === "/raw" || pathname === "/raw/") {
    return await renderFilePageResponse({
      method,
      filePath: appConfig.filePath,
      relativePath: appConfig.relativePath,
      renderedHref: "/",
      rawHref: "/raw",
      backHref: "/",
      activeView: "raw",
    });
  }

  return htmlResponse(renderErrorPage({
    title: "Not found",
    message: "File mode only serves / and /raw.",
    status: 404,
    backHref: "/",
  }), 404, method);
}

/**
 * @param {{ method: string; rootPath: string; routePath: string; activeView: "rendered" | "raw" }} input
 * @returns {Promise<Response>}
 */
async function renderDirectoryFileRoute(input) {
  const decodedPath = decodeRoutePath(input.routePath);
  if (!decodedPath) {
    return htmlResponse(renderErrorPage({
      title: "Invalid path",
      message: "That Markdown path could not be decoded.",
      status: 400,
      backHref: "/",
    }), 400, input.method);
  }

  const resolved = await resolveDirectoryMarkdownPath(input.rootPath, decodedPath);
  if (resolved.kind === "invalid") {
    return htmlResponse(renderErrorPage({
      title: "Invalid path",
      message: "That request points outside the served root.",
      status: 400,
      backHref: "/",
    }), 400, input.method);
  }

  if (resolved.kind === "missing") {
    return htmlResponse(renderErrorPage({
      title: "Not found",
      message: "That Markdown file does not exist.",
      status: 404,
      backHref: "/",
    }), 404, input.method);
  }

  if (resolved.kind === "unsupported") {
    return htmlResponse(renderErrorPage({
      title: "Unsupported type",
      message: "mdview only serves .md and .markdown files.",
      status: 415,
      backHref: "/",
    }), 415, input.method);
  }

  return await renderFilePageResponse({
    method: input.method,
    filePath: resolved.filePath,
    relativePath: resolved.relativePath,
    renderedHref: `/view/${encodeRoutePath(resolved.relativePath)}`,
    rawHref: `/raw/${encodeRoutePath(resolved.relativePath)}`,
    backHref: "/",
    activeView: input.activeView,
  });
}

/**
 * @param {{ method: string; filePath: string; relativePath: string; renderedHref: string; rawHref: string; backHref: string; activeView: "rendered" | "raw" }} input
 * @returns {Promise<Response>}
 */
async function renderFilePageResponse(input) {
  const markdown = await Bun.file(input.filePath).text();
  const title = toFileTitle(input.relativePath);

  if (input.activeView === "raw") {
    return htmlResponse(renderMarkdownPage({
      title,
      relativePath: input.relativePath,
      renderedHref: input.renderedHref,
      rawHref: input.rawHref,
      backHref: input.backHref,
      activeView: input.activeView,
      bodyHtml: `<section class="raw-body"><pre class="raw-block"><code>${escapeHtml(markdown)}</code></pre></section>`,
    }), 200, input.method);
  }

  const rawHtml = Bun.markdown.html(markdown, MARKDOWN_OPTIONS);
  const renderedHtml = transformMermaidBlocks(rawHtml);
  return htmlResponse(renderMarkdownPage({
    title,
    relativePath: input.relativePath,
    renderedHref: input.renderedHref,
    rawHref: input.rawHref,
    backHref: input.backHref,
    activeView: input.activeView,
    bodyHtml: `<article class="markdown-body">${renderedHtml}</article>`,
    hasMermaid: renderedHtml !== rawHtml,
  }), 200, input.method);
}

/**
 * @param {string} rootPath
 * @returns {Promise<MarkdownFile[]>}
 */
async function listMarkdownFiles(rootPath) {
  /** @type {MarkdownFile[]} */
  const files = [];
  await walkDirectory(rootPath, rootPath, files);
  files.sort((left, right) => left.relativePath.localeCompare(right.relativePath));
  return files;
}

/**
 * @param {string} rootPath
 * @param {string} directoryPath
 * @param {MarkdownFile[]} files
 * @returns {Promise<void>}
 */
async function walkDirectory(rootPath, directoryPath, files) {
  const entries = await readdir(directoryPath, { withFileTypes: true });
  entries.sort((left, right) => left.name.localeCompare(right.name));

  for (const entry of entries) {
    if (entry.isSymbolicLink()) continue;

    const entryPath = path.join(directoryPath, entry.name);

    if (entry.isDirectory()) {
      await walkDirectory(rootPath, entryPath, files);
      continue;
    }

    if (!entry.isFile()) continue;
    if (!isMarkdownFile(entryPath)) continue;

    const entryStat = await stat(entryPath);
    files.push({
      absolutePath: entryPath,
      relativePath: toRelativePath(rootPath, entryPath),
      modifiedAt: entryStat.mtime,
    });
  }
}

/**
 * @param {string} rootPath
 * @param {string} requestedPath
 * @returns {Promise<ResolveResult>}
 */
async function resolveDirectoryMarkdownPath(rootPath, requestedPath) {
  if (!requestedPath) return { kind: "invalid" };
  if (requestedPath.includes("\0") || requestedPath.includes("\\")) return { kind: "invalid" };

  const candidatePath = path.resolve(rootPath, requestedPath);
  if (!isWithinPath(rootPath, candidatePath)) return { kind: "invalid" };

  if (!isMarkdownFile(candidatePath)) return { kind: "unsupported" };

  const candidateStat = await getStat(candidatePath);
  if (!candidateStat || !candidateStat.isFile()) return { kind: "missing" };

  const realFilePath = await realpath(candidatePath);
  if (!isWithinPath(rootPath, realFilePath)) return { kind: "invalid" };

  return {
    kind: "ok",
    filePath: realFilePath,
    relativePath: toRelativePath(rootPath, realFilePath),
  };
}

/**
 * @param {string} html
 * @param {number} status
 * @param {string} method
 * @returns {Response}
 */
function htmlResponse(html, status, method) {
  return new Response(method === "HEAD" ? null : html, {
    status,
    headers: {
      "content-type": "text/html; charset=utf-8",
    },
  });
}

/**
 * @param {string} rootPath
 * @param {MarkdownFile[]} files
 * @returns {string}
 */
function renderIndexPage(rootPath, files) {
  const title = path.basename(rootPath) || rootPath;
  const nav = renderNav({
    backHref: "/",
    renderedHref: "/",
    rawHref: null,
    activeView: "index",
  });

  const bodyHtml = files.length === 0
    ? `<section class="surface empty-state"><p>No Markdown files found under this root.</p><p class="meta mono">${escapeHtml(rootPath)}</p></section>`
    : `<section class="surface surface-body"><ul class="file-list">${files.map(renderFileRow).join("")}</ul></section>`;

  return renderDocument({
    title: `${title} · mdview`,
    navHtml: nav,
    contentHtml: `
      <header class="page-header">
        <p class="eyebrow">Directory</p>
        <h1>${escapeHtml(title)}</h1>
        <p class="meta mono">${escapeHtml(rootPath)}</p>
        <p class="meta">${files.length} Markdown file${files.length === 1 ? "" : "s"}</p>
      </header>
      ${bodyHtml}
    `,
  });
}

/**
 * @param {MarkdownFile} file
 * @returns {string}
 */
function renderFileRow(file) {
  const renderedHref = `/view/${encodeRoutePath(file.relativePath)}`;
  const rawHref = `/raw/${encodeRoutePath(file.relativePath)}`;
  const title = toFileTitle(file.relativePath);

  return `
    <li class="file-row">
      <a class="file-card" href="${renderedHref}">
        <p class="file-title">${escapeHtml(title)}</p>
        <p class="file-path mono">${escapeHtml(file.relativePath)}</p>
        <p class="file-time">Updated ${escapeHtml(formatTimestamp(file.modifiedAt))}</p>
      </a>
      <div class="file-actions-row">
        <a class="file-action" href="${rawHref}">Raw</a>
      </div>
    </li>
  `;
}

/**
 * @param {{ title: string; relativePath: string; renderedHref: string; rawHref: string; backHref: string; activeView: "rendered" | "raw"; bodyHtml: string; hasMermaid?: boolean }} input
 * @returns {string}
 */
function renderMarkdownPage(input) {
  return renderDocument({
    title: `${input.title} · mdview`,
    navHtml: renderNav({
      backHref: input.backHref,
      renderedHref: input.renderedHref,
      rawHref: input.rawHref,
      activeView: input.activeView,
    }),
    contentHtml: `
      <header class="page-header">
        <p class="eyebrow">${input.activeView === "raw" ? "Raw" : "Rendered"}</p>
        <h1>${escapeHtml(input.title)}</h1>
        <p class="meta mono">${escapeHtml(input.relativePath)}</p>
      </header>
      ${input.bodyHtml}
    `,
    hasMermaid: input.hasMermaid,
  });
}

/**
 * @param {{ title: string; message: string; status: number; backHref: string | null }} input
 * @returns {string}
 */
function renderErrorPage(input) {
  return renderDocument({
    title: `${input.status} ${input.title} · mdview`,
    navHtml: renderNav({
      backHref: input.backHref,
      renderedHref: input.backHref ?? "/",
      rawHref: null,
      activeView: "error",
    }),
    contentHtml: `
      <header class="page-header">
        <p class="eyebrow">Error ${input.status}</p>
        <h1>${escapeHtml(input.title)}</h1>
        <p class="meta">${escapeHtml(input.message)}</p>
      </header>
      <section class="surface error-body">
        <p>${escapeHtml(input.message)}</p>
        ${input.backHref ? `<p><a href="${input.backHref}">Back to root</a></p>` : ""}
      </section>
    `,
  });
}

/**
 * @param {{ title: string; navHtml: string; contentHtml: string; hasMermaid?: boolean }} input
 * @returns {string}
 */
function renderDocument(input) {
  const mermaidScript = input.hasMermaid
    ? `<script type="module">
  import mermaid from "https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs";
  mermaid.initialize({ startOnLoad: true, theme: document.documentElement.classList.contains("") ? "default" : undefined });
  // Re-init on dark/light mode toggle
  const mq = window.matchMedia("(prefers-color-scheme: dark)");
  const rerender = () => {
    mermaid.initialize({ startOnLoad: false, theme: mq.matches ? "dark" : "default" });
    mermaid.run();
  };
  mq.addEventListener("change", rerender);
</script>`
    : "";

  const langScripts = HIGHLIGHT_LANG_PACKS.map((url) => `<script src="${url}"></script>`).join("\n    ");

  return `<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
    <meta name="color-scheme" content="light dark">
    <title>${escapeHtml(input.title)}</title>
    <link rel="stylesheet" href="${HIGHLIGHT_CSS_URL}">
    <style>${STYLES}</style>
  </head>
  <body>
    <div class="page">
      <nav class="top-nav">${input.navHtml}</nav>
      <main class="shell">${input.contentHtml}</main>
    </div>
    <script src="${HIGHLIGHT_JS_URL}"></script>
    ${langScripts}
    <script>hljs.highlightAll();</script>
    ${mermaidScript}
  </body>
</html>`;
}

/**
 * @param {{ backHref: string | null; renderedHref: string; rawHref: string | null; activeView: "index" | "rendered" | "raw" | "error" }} input
 * @returns {string}
 */
function renderNav(input) {
  const actions = [];

  if (input.backHref) {
    actions.push(`<a class="pill" href="${input.backHref}">Back</a>`);
  }

  actions.push(`<a class="pill ${input.activeView === "rendered" || input.activeView === "index" ? "active" : ""}" href="${input.renderedHref}">${input.activeView === "index" ? "Index" : "Rendered"}</a>`);

  if (input.rawHref) {
    actions.push(`<a class="pill ${input.activeView === "raw" ? "active" : ""}" href="${input.rawHref}">Raw</a>`);
  }

  return `
    <div class="nav-row">
      <a class="brand" href="/">mdview</a>
      <div class="nav-actions">${actions.join("")}</div>
    </div>
  `;
}

/**
 * @param {string} value
 * @returns {string | null}
 */
function decodeRoutePath(value) {
  try {
    return decodeURIComponent(value);
  } catch {
    return null;
  }
}

/**
 * @param {string} value
 * @returns {string}
 */
function encodeRoutePath(value) {
  return value
    .split("/")
    .map((segment) => encodeURIComponent(segment))
    .join("/");
}

/**
 * @param {string} filePath
 * @returns {boolean}
 */
function isMarkdownFile(filePath) {
  return ALLOWED_EXTENSIONS.has(path.extname(filePath).toLowerCase());
}

/**
 * @param {string} rootPath
 * @param {string} targetPath
 * @returns {boolean}
 */
function isWithinPath(rootPath, targetPath) {
  const root = path.resolve(rootPath);
  const target = path.resolve(targetPath);
  const fileSystemRoot = path.parse(root).root;

  if (root === fileSystemRoot) return target.startsWith(root);
  if (target === root) return true;

  return target.startsWith(`${root}${path.sep}`);
}

/**
 * @param {string} rootPath
 * @param {string} filePath
 * @returns {string}
 */
function toRelativePath(rootPath, filePath) {
  return path.relative(rootPath, filePath).split(path.sep).join("/");
}

/**
 * @param {string} relativePath
 * @returns {string}
 */
function toFileTitle(relativePath) {
  const basename = path.basename(relativePath);
  return basename.replace(/\.(md|markdown)$/i, "") || basename;
}

/**
 * @param {Date} date
 * @returns {string}
 */
function formatTimestamp(date) {
  return date.toLocaleString(undefined, {
    dateStyle: "medium",
    timeStyle: "short",
  });
}

/**
 * Convert <pre><code class="language-mermaid">...</code></pre> blocks into
 * <div class="mermaid">...</div> so Mermaid.js can render them client-side.
 * @param {string} html
 * @returns {string}
 */
function transformMermaidBlocks(html) {
  return html.replace(
    /<pre><code class="language-mermaid">([\s\S]*?)<\/code><\/pre>/g,
    (_match, content) => `<div class="mermaid">${unescapeMinimalHtmlEntities(content)}</div>`,
  );
}

/**
 * Decode the minimal set of HTML entities that Bun.markdown.html() emits.
 * @param {string} value
 * @returns {string}
 */
function unescapeMinimalHtmlEntities(value) {
  return value
    .replaceAll("&amp;", "&")
    .replaceAll("&lt;", "<")
    .replaceAll("&gt;", ">")
    .replaceAll("&quot;", '"')
    .replaceAll("&#39;", "'");
}

/**
 * @param {string} value
 * @returns {string}
 */
function escapeHtml(value) {
  return value
    .replaceAll("&", "&amp;")
    .replaceAll("<", "&lt;")
    .replaceAll(">", "&gt;")
    .replaceAll('"', "&quot;")
    .replaceAll("'", "&#39;");
}

/**
 * @param {AppConfig} appConfig
 * @param {CliOptions} options
 */
function printStartupInfo(appConfig, options) {
  const localHost = isExposedHost(options.host) ? "127.0.0.1" : options.host;
  const lanHost = detectLanHost();

  console.log(`mdview serving: ${appConfig.servedPath}`);
  console.log(`mode: ${appConfig.mode}`);
  console.log(`local url: ${buildUrl(localHost, options.port)}`);

  if (isExposedHost(options.host) && lanHost) {
    console.log(`lan url: ${buildUrl(lanHost, options.port)}`);
  }

  if (options.host === DEFAULT_HOST) {
    console.log("warning: server is exposed on all interfaces");
  }
}

/**
 * @returns {string | null}
 */
function detectLanHost() {
  const interfaces = os.networkInterfaces();

  for (const addresses of Object.values(interfaces)) {
    if (!addresses) continue;

    for (const address of addresses) {
      if (address.family !== "IPv4") continue;
      if (address.internal) continue;
      return address.address;
    }
  }

  return null;
}

/**
 * @param {string} host
 * @param {number} port
 * @returns {string}
 */
function buildUrl(host, port) {
  const formattedHost = host.includes(":") && !host.startsWith("[") ? `[${host}]` : host;
  return `http://${formattedHost}:${port}`;
}

/**
 * @param {string} host
 * @returns {boolean}
 */
function isExposedHost(host) {
  return host === "0.0.0.0" || host === "::";
}

/**
 * @param {ReturnType<typeof Bun.serve>} server
 */
function registerShutdown(server) {
  const stop = () => {
    server.stop(true);
    process.exit(0);
  };

  process.on("SIGINT", stop);
  process.on("SIGTERM", stop);
}

/**
 * @param {string} filePath
 * @returns {Promise<import("node:fs").Stats | null>}
 */
async function getStat(filePath) {
  try {
    return await stat(filePath);
  } catch {
    return null;
  }
}

/**
 * @param {unknown} error
 * @returns {boolean}
 */
function isBusyPortError(error) {
  if (!(error instanceof Error)) return false;

  return error.message.includes("EADDRINUSE") || error.message.toLowerCase().includes("address already in use");
}

/**
 * @param {unknown} error
 */
function handleFatalError(error) {
  if (error instanceof Error) fail(error.message);
  fail(String(error));
}

/**
 * @param {string} message
 * @returns {never}
 */
function fail(message) {
  console.error(`error: ${message}`);
  process.exit(1);
}
